{
  "name": "biyesheji-frontend",
  "buildCommand": "npm run build",
  "publishDir": "dist",
  "envVars": {
    "VITE_API_URL": "https://biyesheji.onrender.com/api"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://biyesheji.onrender.com/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/*",
      "dest": "/index.html"
    }
  ]
}
